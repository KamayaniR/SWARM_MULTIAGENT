# Copy to pomerium/.env.pomerium and fill in. Do NOT commit the filled-in file.

# 32-byte base64 secrets — generate each with:  head -c32 /dev/urandom | base64
POMERIUM_SHARED_SECRET=
POMERIUM_COOKIE_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
#   Homepage URL:           https://authenticate.localhost.pomerium.io
#   Authorization callback: https://authenticate.localhost.pomerium.io/oauth2/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# The GitHub-verified email allowed into the dashboard.
SWARM_ALLOWED_EMAIL=himanishprakash23@gmail.com
